# ── LLM ───────────────────────────────────────────────────────────────────────
# Required. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# "gemini" (default, supports vision) or "groq" (faster text, no vision)
LLM_PROVIDER=gemini

# Gemini model — gemini-2.0-flash is free and supports image queries
LLM_MODEL=gemini-2.0-flash

# ── Groq (optional alternative LLM) ───────────────────────────────────────────
# Get a free key at https://console.groq.com  (14,400 req/day free)
# GROQ_API_KEY=

# ── Qdrant vector database ────────────────────────────────────────────────────
# Local (default): run with  docker compose up qdrant -d
QDRANT_URL=http://localhost:6333

# Qdrant Cloud free tier (1 GB) for production — https://cloud.qdrant.io
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your-qdrant-cloud-api-key

# Collection name (created automatically on first upsert)
QDRANT_COLLECTION=rag_chunks

# ── Embeddings ────────────────────────────────────────────────────────────────
# Runs locally on CPU — no API key needed
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Hybrid search tuning ──────────────────────────────────────────────────────
RRF_K=60              # Reciprocal Rank Fusion smoothing constant (paper default)
HYBRID_FETCH_K=20     # Candidates fetched per retriever before fusion

# ── Reranking tuning ──────────────────────────────────────────────────────────
RERANK_FETCH_N=20     # Candidates fetched from hybrid search before reranking
RERANK_TOP_N=5        # Final results returned after cross-encoder reranking
